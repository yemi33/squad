 src: 'pptx/autoLayouts/layouts.md', dst: 'skills/pptx/references/design/layouts.md' },\n   545→                    { src: 'pptx/autoLayouts/layouts_consumer.md', dst: 'skills/pptx/references/design/layouts_consumer.md' },\n   546→                    { src: 'pptx/autoLayouts/content_rules.md', dst: 'skills/pptx/references/rules/content_rules.md' },\n   547→                    { src: 'pptx/autoLayouts/structure_rules.md', dst: 'skills/pptx/references/rules/structure_rules.md' },\n   548→                    { src: 'pptx/autoLayouts/pptx-html-creator-validator.md', dst: 'agents/pptx-html-creator-validator.md' },\n   549→                    { src: 'pptx/autoLayouts/pptx-outline-generator.md', dst: 'agents/pptx-outline-generator.md' }\n   550→                ]\n   551→            }\n   552→        },\n   553→        {\n   554→            // Flight to enable new design system for PPTX - premium component-based\n   555→            // HTML slide generation with 29 themes, 60+ CSS components, and Chart.js integration\n   556→            flightKey: 'OfficeAgent.CreateAgent.NewDesign',\n   557→            applicableVersions: ['1.2.0'],\n   558→            config: {\n   559→                overwrites: [\n   560→                    { src: 'pptx/newDesign/SKILL.md', dst: 'skills/pptx/SKILL.md' },\n   561→                    { src: 'pptx/newDesign/pptx-guidelines.md', dst: 'skills/pptx/CLAUDE.md' },\n   562→                    { src: 'pptx/newDesign/assets/base-template.html', dst: 'skills/pptx/assets/base-template.html' },\n   563→                    { src: 'pptx/newDesign/references/chart-integration.md', dst: 'skills/pptx/references/chart-integration.md' },\n   564→                    { src: 'pptx/newDesign/references/css-components.md', dst: 'skills/pptx/references/css-components.md' },\n   565→                    { src: 'pptx/newDesign/references/extended-components.md', dst: 'skills/pptx/references/extended-components.md' },\n   566→                    { src: 'pptx/newDesign