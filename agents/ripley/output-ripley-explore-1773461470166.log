{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PP8DGYBorYj7DMLmq1SWe1","type":"tool_result","content":"     1→import { OfficeAgentSettingsManager, WebSocketRouter } from '../websocket';\n     2→import { IGroundingSourceToggles, ClientMetadata, McpServers, IMcpToolConfiguration, RequestContext } from '@officeagent/message-protocol';\n     3→import express from 'express';\n     4→import type { AgentWorkspaceManager } from './agent-workspace-manager';\n     5→\n     6→/**\n     7→ * Agent metadata from package.json oagent property\n     8→ */\n     9→export interface IAgent {\n    10→    id: string;\n    11→    name: string;\n    12→    packageName: string;\n    13→    description?: string;\n    14→    version: string;\n    15→}\n    16→\n    17→/**\n    18→ * Configuration for a specific version of an agent\n    19→ */\n    20→export interface AgentVersionConfig {\n    21→    version: string;\n    22→    model: string;\n    23→    maxThinkingTokens: number;\n    24→    maxTurns: number;\n    25→    systemPrompt: string;\n    26→    allowedTools: string[];\n    27→    disallowedTools?: string[];\n    28→    skills: string[];\n    29→    subagents: string[];\n    30→    scripts?: string[];\n    31→    intentDetectionDir?: string[];\n    32→    // Optional post-copy prompt file overwrites applied after artifacts are copied\n    33→    overwrites?: FileOverwrite[];\n    34→    // Optional versioned resources\n    35→    raiGuidelines?: string;\n    36→    // Optional key-value pairs for EJS template rendering in skills, subagents, and scripts\n    37→    templateSettings?: Record<string, unknown>;\n    38→    // Additional version-specific metadata\n    39→    metadata?: Record<string, unknown>;\n    40→    /** Optional effort level hint for the orchestrator (if supported by provider). */\n    41→    effort?: 'low' | 'medium' | 'high' | 'max';\n    42→    /**\n    43→     * Orchestrator harness type. Determines which LLM harness is used at runtime.\n    44→     * Built-in providers: 'claude' (Anthropic Agent SDK), 'ghcp' (GitHub Copilot SDK).\n    45→     * Defaults to 'claude' when unset.\n    46→     */\n    47→    harness?: 'claude' | 'ghcp';\n    48→}\n    49→\n    50→/**\n    51→ * Defines a post-copy overwrite operation.\n    52→ *\n    53→ * Resolution rules:\n    54→ * - `src` is resolved relative to the agent package `dist/src/prompts/{version}/overwrites/` directory.\n    55→ * - `dst` is resolved relative to the `/agent/.claude/` directory.\n    56→ * - If `src` is empty string, the `dst` file/folder will be deleted.\n    57→ *\n    58→ * Example:\n    59→ * ```\n    60→ * overwrites: [\n    61→ *   { src: 'docx/SKILL.md', dst: 'skills/docx/SKILL.md' }\n    62→ * ]\n    63→ * ```\n    64→ * This copies `{pkg}/dist/src/prompts/{version}/overwrites/docx/SKILL.md`\n    65→ * to `/agent/.claude/skills/docx/SKILL.md`.\n    66→ */\n    67→export interface FileOverwrite {\n    68→    /** Source path relative to agent package prompts/{version}/overwrites/ directory */\n    69→    src: string;\n    70→    /** Destination path relative to /agent/.claude/ */\n    71→    dst: string;\n    72→    // Future extensibility: condition, priority, etc.\n    73→}\n    74→\n    75→/**\n    76→ * Flight override configuration\n    77→ * Allows partial overrides of agent config based on flight flags\n    78→ */\n    79→export interface FlightOverride {\n    80→    /** Flight key that triggers this override */\n    81→    flightKey: string;\n    82→    /** Partial configuration to merge when flight is enabled */\n    83→    config: Partial<AgentVersionConfig>;\n    84→    /** Optional: only apply if specific version is active */\n    85→    applicableVersions?: string[];\n    86→}\n    87→\n    88→/**\n    89→ * Filter rule configuration\n    90→ * Defines which config items (skills, subagents, tools) should be removed when a filter is active\n    91→ */\n    92→export interface FilterRule {\n    93→    /** Unique identifier for this filter */\n    94→    filterKey: string;\n    95→    /** Description of what this filter does */\n    96→    description?: string;\n    97→    /** Skills to remove when this filter is active */\n    98→    skills?: string[];\n    99→    /** Subagents to remove when this filter is active */\n   100→    subagents?: string[];\n   101→    /** Scripts to remove when this filter is active */\n   102→    scripts?: string[];\n   103→    /** Allowed tools to remove when this filter is active */\n   104→    allowedTools?: string[];\n   105→}\n   106→\n   107→/**\n   108→ * Runtime filters to apply during config resolution\n   109→ * Maps filter keys to boolean values indicating whether the filter should be applied\n   110→ */\n   111→export type ConfigFilters = Record<string, boolean>;\n   112→\n   113→/**\n   114→ * Complete agent registry configuration\n   115→ */\n   116→export interface AgentRegistryConfig {\n   117→    /** Agent metadata */\n   118→    id: string;\n   119→    name: string;\n   120→    packageName: string;"}]},"parent_tool_use_id":"toolu_01VcS2pjCQDmBrQu85ZKAMvr","session_id":"059c34c4-4758-4e2f-87ba-9357713e7c91","uuid":"64151275-99d6-4bfc-a9e9-21f47f21646b"}
