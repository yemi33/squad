{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Hwr5wRJuvn2S2M8iivHqC9","type":"tool_result","content":"     1→import { AgentRegistry, BaseAgent, logInfo } from '@officeagent/core';\n     2→import { PptCreationAgent } from '@officeagent/ppt-creation-agent';\n     3→import { PptEditAgent } from '@officeagent/ppt-edit-agent';\n     4→import { CreateAgent } from '@officeagent/create-agent';\n     5→import { GPTCreateAgent } from '@officeagent/gpt-create-agent';\n     6→import { DWParalegalAgent } from '@officeagent/dw-paralegal-agent';\n     7→import { DWMarketerAgent } from '@officeagent/dw-marketer-agent';\n     8→import { ODSPAgent } from '@officeagent/odsp-agent';\n     9→import { DWAccountantAgent } from '@officeagent/dw-accountant-agent';\n    10→import { PptAgent } from '@officeagent/ppt-agent';\n    11→import { GroundingAgent } from '@officeagent/grounding-agent';\n    12→import { ExcelJsRunnerAgent } from '@officeagent/excel-js-runner-agent';\n    13→import { ExcelAgent } from '@officeagent/excel-agent';\n    14→import { WorkspaceAgent } from '@officeagent/workspace-agent';\n    15→import { OfficeAgent } from '@officeagent/office-agent';\n    16→\n    17→/**\n    18→ * Register all agents with the AgentRegistry.\n    19→ */\n    20→export function registerAgents(): void {\n    21→    logInfo(0x1e09c1cf /* tag_4c2hp */, '[Agent Registration] Registering all agents');\n    22→\n    23→    const agents: BaseAgent[] = [\n    24→        // Create agent variants - each with unique agentId\n    25→        new CreateAgent(),           // id: 'create-agent' (Claude)\n    26→        new GPTCreateAgent(),        // id: 'create-agent-gpt'\n    27→        // Digital Worker agents\n    28→        new DWAccountantAgent(),\n    29→        new DWParalegalAgent(),\n    30→        new DWMarketerAgent(),       // id: 'dw-marketer-agent' (Marketing DW)\n    31→        // Workspace agent\n    32→        new WorkspaceAgent(),        // id: 'workspace-agent'\n    33→        // Other agents\n    34→        new ODSPAgent(),\n    35→        new PptCreationAgent(),\n    36→        new PptEditAgent(),\n    37→        new ExcelJsRunnerAgent(),    // id: 'excel-js-runner-agent'\n    38→        new ExcelAgent(),            // id: 'excel-agent' (Copilot SDK)\n    39→        // PPT Agent - Opus 4.6 + Anthropic PPTX Skill\n    40→        new PptAgent(),\n    41→        new GroundingAgent(),      // id: 'grounding-agent'\n    42→        new OfficeAgent(),  // id: 'office-agent' (Copilot SDK)\n    43→    ];\n    44→\n    45→    for (const agent of agents) {\n    46→        AgentRegistry.registerAgent(agent);\n    47→        logInfo(0x1e0dc203 /* tag_4d2id */, `Registered agent: ${agent.agentId} (${agent.version})`);\n    48→    }\n    49→}\n    50→"}]},"parent_tool_use_id":"toolu_01VcS2pjCQDmBrQu85ZKAMvr","session_id":"059c34c4-4758-4e2f-87ba-9357713e7c91","uuid":"c545084b-c0a5-4532-85db-c7c84b8bb494"}
