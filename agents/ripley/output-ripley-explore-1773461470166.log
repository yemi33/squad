{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013geey2xJZsR5uec2eyJymC","type":"tool_result","content":"   116→export interface AgentRegistryConfig {\n   117→    /** Agent metadata */\n   118→    id: string;\n   119→    name: string;\n   120→    packageName: string;\n   121→    description?: string;\n   122→\n   123→    /** Default version to use (optional for simple agents) */\n   124→    defaultVersion?: string;\n   125→\n   126→    /** All available version configurations (optional for simple agents) */\n   127→    versions?: AgentVersionConfig[];\n   128→\n   129→    /** Optional flight-based overrides */\n   130→    flights?: FlightOverride[];\n   131→\n   132→    /** Optional filter rules for removing config items based on runtime conditions */\n   133→    filters?: FilterRule[];\n   134→}\n   135→\n   136→/**\n   137→ * Resolved agent configuration\n   138→ * Created after applying version selection, flights, and filters\n   139→ */\n   140→export interface ResolvedAgentConfig extends AgentVersionConfig {\n   141→    /** Agent metadata */\n   142→    id: string;\n   143→    name: string;\n   144→    description?: string;\n   145→    packageName: string;\n   146→\n   147→    /** Applied flights (populated after flight resolution) */\n   148→    appliedFlights?: string[];\n   149→\n   150→    /** Applied filters (populated after filter resolution) */\n   151→    appliedFilters?: string[];\n   152→}\n   153→\n   154→/**\n   155→ * Turn context for hooks that need turn-specific information\n   156→ */\n   157→export interface TurnContext {\n   158→    /** Workspace manager for accessing turn-specific information and directories */\n   159→    workspaceManager: AgentWorkspaceManager;\n   160→    /** Request context containing query annotations and other turn-specific data */\n   161→    requestContext?: RequestContext;\n   162→}\n   163→\n   164→/**\n   165→ * Session context passed to agent initialization\n   166→ */\n   167→export interface SessionContext {\n   168→    requestId: string;\n   169→    sessionId: string;\n   170→    conversationId: string;\n   171→    agentId: string;\n   172→    wsRouter: WebSocketRouter;\n   173→    internalApp?: express.Application;\n   174→    settingsManager?: OfficeAgentSettingsManager;\n   175→    groundingSourceToggles?: IGroundingSourceToggles;\n   176→    clientMetadata?: ClientMetadata;\n   177→    sessionStartTime?: string;\n   178→    mcpServers?: McpServers;\n   179→    mcpToolConfiguration?: IMcpToolConfiguration;\n   180→}\n   181→"}]},"parent_tool_use_id":"toolu_01VcS2pjCQDmBrQu85ZKAMvr","session_id":"059c34c4-4758-4e2f-87ba-9357713e7c91","uuid":"78a62049-2325-4cdb-9477-6276ba8f37a3"}
