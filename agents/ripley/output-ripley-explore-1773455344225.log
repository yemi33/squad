gInfo(0x1e09070b /* tag_4cq2l */, `Process beforeExit with code: ${code}`);\n   512→});\n   513→\n   514→process.on('SIGTERM', () => {\n   515→    logError(0x1e09070e /* tag_4cq2o */, 'Received SIGTERM signal. Shutting down gracefully...');\n   516→    process.exit(0);\n   517→});\n   518→\n   519→// Handle warnings\n   520→process.on('warning', (warning) => {\n   521→    logWarn(0x1e09070d /* tag_4cq2n */, `Process warning: ${warning.name} - ${warning.message} - Stack:${warning.stack || ''}`);\n   522→});\n   523→"}]},"parent_tool_use_id":"toolu_01AU7kaGXRrmfPoh4L8qumog","session_id":"98ef6066-2367-415b-b616-f95ed64be17a","uuid":"cbff402c-71a2-43f9-8aa5-6601b2af0612"}
