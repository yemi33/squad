{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01B8TUHwFvT8nf6fg2aJbJCS","type":"tool_result","content":"     1→/**\n     2→ * Base preprocessor class with common validation logic.\n     3→ *\n     4→ * Preprocessors are responsible for:\n     5→ * - Validating input requests\n     6→ * - Enriching requests with additional metadata\n     7→ * - Building substrate search requests (for search operations)\n     8→ *\n     9→ * @module enterprise-grounding/preprocessing\n    10→ */\n    11→\n    12→import {\n    13→    IPreprocessor,\n    14→    PipelineContext,\n    15→    PreprocessingError\n    16→} from './types';\n    17→import { logDebug, logError } from '@officeagent/core';\n    18→\n    19→/**\n    20→ * Abstract base class for all preprocessors.\n    21→ * Provides common validation and execution structure.\n    22→ */\n    23→export abstract class BasePreprocessor<TRaw, TProcessed> implements IPreprocessor<TRaw, TProcessed> {\n    24→    public abstract readonly name: string;\n    25→\n    26→    /**\n    27→     * Execute the preprocessing stage\n    28→     */\n    29→    public async execute(input: TRaw, context: PipelineContext): Promise<TProcessed> {\n    30→        const startTime = Date.now();\n    31→        logDebug(`[${this.name}] Starting preprocessing for request ${context.requestId}`);\n    32→\n    33→        try {\n    34→            // Validate input\n    35→            this.validate(input);\n    36→\n    37→            // Perform preprocessing transformation\n    38→            const result = await this.process(input, context);\n    39→\n    40→            // Track timing\n    41→            const duration = Date.now() - startTime;\n    42→            if (context.timings) {\n    43→                context.timings.preprocessing = duration;\n    44→            }\n    45→\n    46→            logDebug(`[${this.name}] Completed preprocessing in ${duration}ms`);\n    47→            return result;\n    48→        } catch (error: any) {\n    49→            logError(0x1e06065e /* tag_4b6z4 */, `[${this.name}] Preprocessing failed: ${error.message}`);\n    50→            throw new PreprocessingError(\n    51→                `Preprocessing failed: ${error.message}`,\n    52→                { originalError: error.message, input }\n    53→            );\n    54→        }\n    55→    }\n    56→\n    57→    /**\n    58→     * Validate the input request.\n    59→     * Throws PreprocessingError if validation fails.\n    60→     */\n    61→    protected abstract validate(input: TRaw): void | PreprocessingError;\n    62→\n    63→    /**\n    64→     * Perform the actual preprocessing transformation.\n    65→     * Subclasses implement specific preprocessing logic here.\n    66→     */\n    67→    protected abstract process(input: TRaw, context: PipelineContext): Promise<TProcessed>;\n    68→}\n    69→"}]},"parent_tool_use_id":"toolu_01AU7kaGXRrmfPoh4L8qumog","session_id":"98ef6066-2367-415b-b616-f95ed64be17a","uuid":"64519baa-789c-4802-b4ad-6e9a6df414e1"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01EEyfW4wdxYFWrB5dTB3jR6","type":"tool_result","content":"     1→import { logError, logInfo } from '@officeagent/core';\n     2→import { IOrchestrator, IPipelineStage, IPostprocessor, IPreprocessor, IRetriever, IStorage, PipelineContext } from './types';\n     3→\n     4→export class Orchestrator<TRequest, TResult> implements IOrchestrator<TRequest, TResult> {\n     5→    constructor(\n     6→        private readonly orchestratorName: string,\n     7→        private readonly preprocessor: IPreprocessor<TRequest, any> | IPreprocessor<any, any>[],\n     8→        private readonly retriever: IRetriever<any, any>,\n     9→        private readonly postProcessor: IPostprocessor<any, any> | IPostprocessor<any, any>[],\n    10→        private readonly storage: IStorage<any, TResult> | IStorage<any, TResult>[],\n    11→    ) { }\n    12→\n    13→    public async execute(request?: TRequest, context?: Partial<PipelineContext>): Promise<TResult> {\n    14→        const pipelineContext: PipelineContext = {\n    15→            requestId: context?.requestId ?? `orchestrator-${Date.now()}`,\n    16→            sessionId: context?.sessionId ?? 'default',\n    17→            timestamp: context?.timestamp ?? new Date(),\n    18→            workspaceDir: context?.workspaceDir ?? null,\n    19→            metadata: context?.metadata ?? {},\n    20→            timings: {},\n    21→            settingsManager: context?.settingsManager,\n    22→        };\n    23→\n    24→        logInfo(0x1e09971d /* tag_4cz23 */, `[${this.orchestratorName}] Starting pipeline, fetchRequestId: ${pipelineContext.requestId}`);\n    25→\n    26→        try {\n    27→            // Stage 1: Preprocessing\n    28→            const startPreprocess = Date.now();\n    29→            logInfo(0x1e09971c /* tag_4cz22 */, `[${this.orchestratorName}] Preprocessing started, fetchRequestId: ${pipelineContext.requestId}`);\n    30→            const processedRequest = await this.executeStage(this.preprocessor, request ?? {} as TRequest, pipelineContext);\n    31→            pipelineContext.timings!.preprocessing = Date.now() - startPreprocess;\n    32→            logInfo(0x1e09971b /* tag_4cz21 */, `[${this.orchestratorName}] Preprocessing completed in ${pipelineContext.timings!.preprocessing}ms, fetchRequestId: ${pipelineContext.requestId}`);\n    33→\n    34→            // Stage 2: Retrieval\n    35→            const startRetrieval = Date.now();\n    36→            logInfo(0x1e09971a /* tag_4cz20 */, `[${this.orchestratorName}] Retrieval started, fetchRequestId: ${pipelineContext.requestId}`);\n    37→            const rawResponse = await this.retriever.execute(processedRequest, pipelineContext);\n    38→            pipelineContext.timings!.retrieval = Date.now() - startRetrieval;\n    39→            logInfo(0x1e099719 /* tag_4cz2z */, `[${this.orchestratorName}] Retrieval completed in ${pipelineContext.timings!.retrieval}ms, fetchRequestId: ${pipelineContext.requestId}`);\n    40→\n    41→            // Stage 3: Postprocessing\n    42→            const startPostprocess = Date.now();\n    43→            logInfo(0x1e099718 /* tag_4cz2y */, `[${this.orchestratorName}] Postprocessing started, fetchRequestId: ${pipelineContext.requestId}`);\n    44→            const processedResponse = await this.executeStage(this.postProcessor, rawResponse, pipelineContext);\n    45→            pipelineContext.timings!.postprocessing = Date.now() - startPostprocess;\n    46→            logInfo(0x1e099717 /* tag_4cz2x */, `[${this.orchestratorName}] Postprocessing completed in ${pipelineContext.timings!.postprocessing}ms, fetchRequestId: ${pipelineContext.requestId}`);\n    47→\n    48→            // Stage 4: Storage\n    49→            const startPersist = Date.now();\n    50→            logInfo(0x1e099716 /* tag_4cz2w */, `[${this.orchestratorName}] Storage started, fetchRequestId: ${pipelineContext.requestId}`);\n    51→            const persistedResponse = await this.executeStage(this.storage, processedResponse, pipelineContext);\n    52→            pipelineContext.timings!.storage = Date.now() - startPersist;\n    53→            logInfo(0x1e099715 /* tag_4cz2v */, `[${this.orchestratorName}] Storage completed in ${pipelineContext.timings!.storage}ms, fetchRequestId: ${pipelineContext.requestId}`);\n    54→\n    55→            const totalTime = Object.values(pipelineContext.timings!).reduce((sum, time) => sum + time, 0);\n    56→            logInfo(0x1e099714 /* tag_4cz2u */, `[${this.orchestratorName}] Pipeline completed successfully in ${totalTime}ms, fetchRequestId: ${pipelineContext.requestId}`);\n    57→\n    58→            return persistedResponse as TResult;\n    59→        } catch (error) {\n    60→            logError(0x1e099713 /* tag_4cz2t */, `[${this.orchestratorName}] Pipeline failed: ${error}, fetchRequestId: ${pipelineContext.requestId}`);\n    61→            throw error;\n    62→        }\n    63→    }\n    64→\n    65→    // execute a pipeline stage\n    66→    private async executeStage<TInput, TOutput, IStage extends IPipelineStage<TInput, TOutput> | IPipelineStage<TInput, TOutput>[]>(stage: IStage, input: TInput, context: PipelineContext): Promise<TOutput> {\n    67→        if (!Array.isArray(stage)) {\n    68→            logInfo(0x1e099712 /* tag_4cz2s */, `[${this.orchestratorName}] Executing stage: ${stage.name}, fetchRequestId: ${context.requestId}`);\n    69→            return await stage.execute(input, context);\n    70→        }\n    71→\n    72→        let currentInput: any = input;\n    73→        for (const currentStage of stage) {\n    74→            logInfo(0x1e099711 /* tag_4cz2r */, `[${this.orchestratorName}] Executing stage: ${currentStage.name}, fetchRequestId: ${context.requestId}`);\n    75→            currentInput = await currentStage.execute(currentInput, context);\n    76→        }\n    77→\n    78→        return currentInput;\n    79→    }\n    80→}\n    81→"}]},"parent_tool_use_id":"toolu_01AU7kaGXRrmfPoh4L8qumog","session_id":"98ef6066-2367-415b-b616-f95ed64be17a","uuid":"eef5ff0b-32e7-4f45-a888-cb3a30be6df6"}
