ntClientMetadata: ClientMetadata | null = null;\n   107→\n   108→// Track active conversations to prevent concurrent requests\n   109→const activeConversations = new Set<string>();\n   110→\n   111→// Function to get the current conversation ID (for handlers)\n   112→function getConversationId(): string | null {\n   113→    return currentConversationId;\n   114→}\n   115→\n   116→// Function to get the current output directory (for handlers)\n   117→function getOutputDir(): string | null {\n   118→    return currentOutputDir;\n   119→}\n   120→\n   121→// Function to get the settings manager (for handlers)\n   122→function getSettings(): OfficeAgentSettingsManager {\n   123→    return settingsManager;\n   124→}\n   125→\n   126→function setClientMetadata(metadata: ClientMetadata): void {\n   127→    currentClientMetadata = metadata;\n   128→}\n   129→\n   130→function getClientMetadata(): ClientMetadata | null {\n   131→    return currentClientMetadata;\n   132→}\n   133→\n   134→let resolveSessionInitComplete: (() => void) | undefined;\n   135→let sessionInitCompletePromise = new Promise<void>((resolve) => { resolveSessionInitComplete = resolve; });\n   136→\n   137→const wss = new WebSocket.Server({\n   138→    server: externalServer,\n   139→    path: '/ws',\n   140→    maxPayload: 100 * 1024 * 1024  // 100 MB max payload size\n   141→});\n   142→\n   143→// Register PptAgent session handler on wsRouter (uses existing /ws connection)\n   144→registerPptAgentSessionHandler();\n   145→\n   146→externalServer.on('request', externalApp);\n   147→externalServer.listen(externalPort, () => {\n   148→    logInfo(0x1e0dc1ce /* tag_4d2ho */, `🚀 HTTP API server is running on http://localhost:${externalPort}`);\n   149→    logInfo(0x1e0dc1cd /* tag_4d2hn */, `📡 WebSocket server is running on http://localhost:${externalPort}/ws`);\n   150→    logInfo(0x1e0dc1cc /* tag_4d2hm */, `❤️ Health check endpoint: GET http://localhost:${externalPort}/health`);\n   151→    logInfo(0x1e0