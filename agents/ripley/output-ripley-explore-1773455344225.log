{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014xgCfz4ZEumaysk77M515v","type":"tool_result","content":"     1→/**\n     2→ * Agent type identifiers for Office document generation\n     3→ *\n     4→ * Maps agent names to their normalized hook registry keys.\n     5→ * Used with HookRegistry to load agent-specific hooks dynamically.\n     6→ */\n     7→export enum AgentType {\n     8→    /** Word document agent - generates .docx files */\n     9→    WordAgent = 'word',\n    10→    /** Excel spreadsheet agent - generates .xlsx files */\n    11→    ExcelAgent = 'excel',\n    12→    /** PowerPoint presentation agent - generates .pptx files */\n    13→    PowerPointAgent = 'powerpoint',\n    14→}\n    15→\n    16→/**\n    17→ * Information about a file generated during document creation\n    18→ * Used for documents created on the container by the agent\n    19→ */\n    20→export interface GeneratedFileInfo {\n    21→    filename: string;\n    22→    filePath: string;\n    23→    size: number;\n    24→}\n    25→\n    26→/**\n    27→ * Information about external documents (e.g., Excel files created via headless API)\n    28→ */\n    29→export interface ExternalDocumentInfo {\n    30→    fileName?: string;\n    31→    webUrl?: string;\n    32→    documentUrl?: string;\n    33→    isEdit?: boolean; // true = edited existing file, false = created new file\n    34→    fileId?: string;\n    35→    driveId?: string;\n    36→    driveItemId?: string;\n    37→    error?: string; // Error message if file operation failed\n    38→}\n    39→\n    40→/**\n    41→ * Callbacks for tracking document generation lifecycle\n    42→ */\n    43→export interface DocumentGenerationCallbacks {\n    44→    /** Called when document generation is attempted */\n    45→    onDocumentGenerationAttempted?: (fileInfo?: ExternalDocumentInfo) => void;\n    46→    /** Called when document generation is completed successfully */\n    47→    onDocumentGenerationCompleted?: (fileInfo?: ExternalDocumentInfo) => void;\n    48→    /** Called when document generation fails */\n    49→    onDocumentGenerationFailed?: (fileInfo?: ExternalDocumentInfo) => void;\n    50→}\n    51→"}]},"parent_tool_use_id":"toolu_01VbaCZT2x5MAVT4SegakNyh","session_id":"98ef6066-2367-415b-b616-f95ed64be17a","uuid":"fa8c1335-539d-44f7-957c-481a202b762e"}
