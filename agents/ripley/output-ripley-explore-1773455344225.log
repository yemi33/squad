{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014Wy9SoBg4LFcYc1zvwHdKe","type":"tool_result","content":"     1→/**\n     2→ * @officeagent/message-protocol/types\n     3→ *\n     4→ * WebSocket message protocol contract\n     5→ */\n     6→\n     7→import { MessageType } from './message-type';\n     8→import type { Message as SydneyMessage } from '@augloop-types/sydney';\n     9→\n    10→// Re-export MessageType for convenience\n    11→export { MessageType };\n    12→export { Message as SydneyMessage } from '@augloop-types/sydney';\n    13→\n    14→/**\n    15→ * Base schema interface for all messages\n    16→ */\n    17→export interface Schema {\n    18→    /** What this message is */\n    19→    type: MessageType;\n    20→    /** Message ID */\n    21→    id: string;\n    22→}\n    23→\n    24→/**\n    25→ * Base message interface for all WebSocket messages\n    26→ * @template T - The type of the payload\n    27→ */\n    28→export interface Message<T = unknown> extends Schema {\n    29→    /** Session which message is for */\n    30→    sessionId: string;\n    31→    /** Message payload - can be any object */\n    32→    payload: T;\n    33→}\n    34→\n    35→/**\n    36→ * Response message interface that extends base Message\n    37→ * Used for messages that are responses to previous requests\n    38→ */\n    39→export interface ResponseMessage<T = unknown> extends Message<T> {\n    40→    /** ID of the request this is responding to */\n    41→    requestId: string;\n    42→}\n    43→\n    44→/**\n    45→ * OfficePy Settings\n    46→ * Contains configuration settings to be passed to the OfficePy container\n    47→ * Each setting is a key-value pair where the value can be boolean, string, or number\n    48→ */\n    49→export interface OfficePySettings {\n    50→    /** Settings as key-value pairs */\n    51→    [key: string]: boolean | string | number | object;\n    52→}\n    53→\n    54→/**\n    55→ * Scenario type enum for differentiating between enterprise and consumer contexts\n    56→ * Used to filter themes, layouts, and other scenario-specific features\n    57→ */\n    58→export enum ScenarioType {\n    59→    /** Consumer/personal use scenarios */\n    60→    Consumer = 'consumer',\n    61→    /** Enterprise/business use scenarios */\n    62→    Enterprise = 'enterprise'\n    63→}\n    64→\n    65→/**\n    66→ * Grounding Source flags to enable or disable specific grounding sources\n    67→ * Contains OCPS (Office Copilot Service) policy settings and user sources preferences that control feature availability\n    68→ */\n    69→export interface IGroundingSourceToggles {\n    70→    /** Flag to enable/disable web search functionality */\n    71→    webSearch: boolean;\n    72→\n    73→    /** Flag to enable/disable enterprise search */\n    74→    enterpriseSearch: boolean;\n    75→}\n    76→\n    77→/**\n    78→ * Client metadata containing details about the client calling Agents\n    79→ */\n    80→export interface ClientMetadata {\n    81→    /** Name of the application (e.g., \"Word\", \"Excel\", \"PowerPoint\", \"BizChat\") */\n    82→    appName: string;\n    83→    /** Platform the application is running on (e.g., \"Windows\", \"Mac\", \"Web\", \"iOS\", \"Android\") */\n    84→    appPlatform: string;\n    85→    /** Name of client facing agent (e.g., \"WordAgent\", \"OfficeAgent\") */\n    86→    agentName?: string;\n    87→}\n    88→\n    89→// the value will actually be a ListToolsResult type (from mcp sdk), but we don't want to take a dependency on that package here, so we use unknown\n    90→export type McpServers = Record<string, unknown>;\n    91→\n    92→export interface IMcpToolConfiguration {\n    93→    mcpTools: string[];\n    94→    mcpToolsFilePath: string | null;\n    95→    localMcpServerName: string;\n    96→}\n    97→\n    98→/**\n    99→ * Session Initialization Message Payload\n   100→ * Payload sent to initialize a session with the OfficePy container"}]},"parent_tool_use_id":"toolu_01AU7kaGXRrmfPoh4L8qumog","session_id":"98ef6066-2367-415b-b616-f95ed64be17a","uuid":"3d1a3dd6-aa48-44e0-8595-eb17a3e69443"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01C8pbMCozbKuPMLPGZPpyoq","type":"tool_result","content":"     1→/**\n     2→ * @officeagent/message-protocol/types/message-type\n     3→ *\n     4→ * Message type enum for all supported message types\n     5→ */\n     6→\n     7→/**\n     8→ * Message type enum for all supported message types in the WebSocket protocol\n     9→ */\n    10→export enum MessageType {\n    11→    // Internal message types\n    12→    Welcome = 'welcome',\n    13→    Ping = 'ping',\n    14→    Pong = 'pong',\n    15→    Error = 'error',\n    16→    SessionInit = 'session_init',\n    17→    SessionInitResponse = 'session_init_response',\n    18→    // Claude/Anthropic LLM messages\n    19→    LLMRequest = 'llm_request',\n    20→    LLMResponse = 'llm_response',\n    21→    // OpenAI model messages (Azure/Substrate)\n    22→    OpenAILLMRequest = 'openai_request',\n    23→    OpenAILLMResponse = 'openai_response',\n    24→    Telemetry = 'telemetry',\n    25→\n    26→    // Enterprise search related messages\n    27→    EnterpriseSearchRequest = 'enterprise_search_request',\n    28→    EnterpriseSearchResponse = 'enterprise_search_response',\n    29→    EnterpriseSearchError = 'enterprise_search_error',\n    30→    EnterpriseFetchRequest = 'enterprise_fetch_request',\n    31→    EnterpriseFetchResponse = 'enterprise_fetch_response',\n    32→    EnterpriseFetchError = 'enterprise_fetch_error',\n    33→    EnterpriseSearchSubstrateError = 'enterprise_search_substrate_error',\n    34→    EnterpriseSearchSydneyRequest = 'enterprise_search_sydney_request',\n    35→    EnterpriseSearchSydneyResponse = 'enterprise_search_sydney_response',\n    36→    EnterpriseFileSearchRequest = 'enterprise_file_search_request',\n    37→    EnterpriseFileSearchResponse = 'enterprise_file_search_response',\n    38→    EnterpriseFileSearchResultItem = 'enterprise_file_search_result_item',\n    39→    EnterpriseEmailSearchRequest = 'enterprise_email_search_request',\n    40→    EnterpriseEmailSearchResponse = 'enterprise_email_search_response',\n    41→    EnterpriseEmailSearchResultItem = 'enterprise_email_search_result_item',\n    42→    EnterpriseChatSearchRequest = 'enterprise_chat_search_request',\n    43→    EnterpriseChatSearchResponse = 'enterprise_chat_search_response',\n    44→    EnterpriseChatSearchResultItem = 'enterprise_chat_search_result_item',\n    45→    EnterpriseTranscriptSearchRequest = 'enterprise_transcript_search_request',\n    46→    EnterpriseTranscriptSearchResponse = 'enterprise_transcript_search_response',\n    47→    EnterpriseTranscriptSearchResultItem = 'enterprise_transcript_search_result_item',\n    48→    EnterpriseMeetingSearchRequest = 'enterprise_meeting_search_request',\n    49→    EnterpriseMeetingSearchResponse = 'enterprise_meeting_search_response',\n    50→    EnterpriseMeetingSearchResultItem = 'enterprise_meeting_search_result_item',\n    51→    EnterprisePeopleSearchRequest = 'enterprise_people_search_request',\n    52→    EnterprisePeopleSearchResponse = 'enterprise_people_search_response',\n    53→    EnterprisePeopleSearchResultItem = 'enterprise_people_search_result_item',\n    54→    EnterpriseCalendarSearchRequest = 'enterprise_calendar_search_request',\n    55→    EnterpriseCalendarSearchResponse = 'enterprise_calendar_search_response',\n    56→    EnterpriseCalendarSearchResultItem = 'enterprise_calendar_search_result_item',\n    57→\n    58→    SourceAttributionsRequest = 'source_attributions_request',\n    59→    SourceAttributionsResponse = 'source_attributions_response',\n    60→\n    61→    // Citation injection (for PPTX, Word, Excel)\n    62→    CitationInjectionRequest = 'citation_injection_request',\n    63→    CitationInjectionResponse = 'citation_injection_response',\n    64→\n    65→    ExcelExecuteOfficeJsRequest = 'excel_execute_officejs_request',\n    66→    ExcelExecuteOfficeJsResponse = 'excel_execute_officejs_response',\n    67→    ExcelCreateFileRequest = 'excel_create_file_request',\n    68→    ExcelCreateFileResponse = 'excel_create_file_response',\n    69→    ExcelGetFileMetadataRequest = 'excel_get_file_metadata_request',\n    70→    ExcelGetFileMetadataResponse = 'excel_get_file_metadata_response',\n    71→    ExcelDownloadFileRequest = 'excel_download_file_request', // DEV ONLY\n    72→    ExcelDownloadFileResponse = 'excel_download_file_response', // DEV ONLY\n    73→    // ExcelRunScript messages (AugLoop <-> OfficeAgent for sandboxed script execution)\n    74→    ExcelRunScriptRequest = 'excel_run_script_request',\n    75→    ExcelRunScriptResponse = 'excel_run_script_response',\n    76→    UpdateSensitivityLabelRequest = 'update_sensitivity_label_request',\n    77→    UpdateSensitivityLabelResponse = 'update_sensitivity_label_response',\n    78→    UploadFileToSharePointRequest = 'upload_file_to_sharepoint_request',\n    79→    UploadFileToSharePointResponse = 'upload_file_to_sharepoint_response',\n    80→    ImageSearchRequest = 'image_search_request',\n    81→    ImageSearchResponse = 'image_search_response',\n    82→    ImageSearchResultItem = 'image_search_result_item',\n    83→    InterruptQueryRequest = 'interrupt_query_request',\n    84→    MCPRequest = 'mcp_request',\n    85→    MCPResponse = 'mcp_response',\n    86→    WebSearchRequestMessage = 'web_search_request',\n    87→    WebSearchResponseMessage = 'web_search_response',\n    88→    WebFetchRequestMessage = 'web_fetch_request',\n    89→    WebFetchResponseMessage = 'web_fetch_response',\n    90→    WebSearchError = 'web_search_error',\n    91→    WebFetchError = 'web_fetch_error',\n    92→    ImageSearchError = 'image_search_error',\n    93→    QueryStatus = 'query_status',\n    94→    UserContextRequest = 'user_context_request',\n    95→    UserContextResponse = 'user_context_response',\n    96→\n    97→    HtmlParseRequest = 'html_parse_request',\n    98→    HtmlParseResult = 'html_parse_result',\n    99→    HtmlRenderRequest = 'html_render_request',\n   100→    HtmlRenderResult = 'html_render_result',"}]},"parent_tool_use_id":"toolu_01AU7kaGXRrmfPoh4L8qumog","session_id":"98ef6066-2367-415b-b616-f95ed64be17a","uuid":"5e251be5-530e-44a9-a5b2-21077fa1708a"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013pspfoT9529YH6M4TPnx6S","type":"tool_result","content":"     1→/**\n     2→ * JSON-RPC 2.0 Protocol for WebSocket Communication\n     3→ */\n     4→\n     5→import { JsonRpcErrorCode } from './error-code';\n     6→import { JsonRpcMethod } from './methods';\n     7→\n     8→/** JSON-RPC protocol version */\n     9→export const JSONRPC_VERSION = '2.0' as const;\n    10→\n    11→// ============================================================================\n    12→// JSON-RPC Base Types\n    13→// ============================================================================\n    14→\n    15→export interface JsonRpcBase {\n    16→    /** JSON-RPC version, always \"2.0\" */\n    17→    jsonrpc: typeof JSONRPC_VERSION;\n    18→    /** CorrelationVector for logging correlation. */\n    19→    cv?: string;\n    20→}\n    21→\n    22→/**\n    23→ * JSON-RPC Request (MUST have id - expects a response)\n    24→ *\n    25→ * Use requests when:\n    26→ * - You need a response from the receiver\n    27→ * - You want to correlate responses with requests (using id)\n    28→ */\n    29→export interface JsonRpcRequest extends JsonRpcBase {\n    30→    /** Method name to invoke */\n    31→    method: JsonRpcMethod;\n    32→    /** Method parameters (by-name as object) */\n    33→    params?: Record<string, any>;\n    34→    /** Request identifier - REQUIRED for requests that expect responses */\n    35→    id: string | number;\n    36→}\n    37→\n    38→/**\n    39→ * JSON-RPC Notification (MUST NOT have id - no response expected)\n    40→ *\n    41→ * Use notifications when:\n    42→ * - You don't need or want a response\n    43→\n    44→ * Examples:\n    45→ * - chain_of_thought: Server sends thinking process updates to client\n    46→ */\n    47→export interface JsonRpcNotification extends JsonRpcBase {\n    48→    /** Method name to invoke */\n    49→    method: string;\n    50→    /** Method parameters (by-name as object) */\n    51→    params?: Record<string, any>;\n    52→    // Note: No id field - notifications don't expect responses\n    53→}\n    54→\n    55→/**\n    56→ * JSON-RPC Response (MUST have id to correlate with request)\n    57→ *\n    58→ * Use responses when:\n    59→ * - Replying to a JsonRpcRequest (id matches the request id)\n    60→ */\n    61→export interface JsonRpcResponse extends JsonRpcBase {\n    62→    /** Success result (mutually exclusive with error) */\n    63→    result?: any;\n    64→    /** Error details (mutually exclusive with result) */\n    65→    error?: JsonRpcError;\n    66→    /** Response identifier - matches the request id */\n    67→    id: string | number | null;\n    68→}\n    69→\n    70→export type JsonRpcMessage = JsonRpcRequest | JsonRpcNotification | JsonRpcResponse;\n    71→\n    72→export interface JsonRpcError {\n    73→    /** Error code */\n    74→    code: JsonRpcErrorCode;\n    75→    /** Short error description */\n    76→    message?: string;\n    77→    /** Additional error information */\n    78→    data?: any;\n    79→}\n    80→\n    81→// ============================================================================\n    82→// Type Guard Functions\n    83→// ============================================================================\n    84→\n    85→/**\n    86→ * Type guard to check if a message is a JSON-RPC Request\n    87→ * @param message - Message to check\n    88→ * @returns true if message is a valid JSON-RPC request\n    89→ */\n    90→export function isJsonRpcRequest(message: any): message is JsonRpcRequest {\n    91→    return Boolean(\n    92→        message &&\n    93→        typeof message === 'object' &&\n    94→        message.jsonrpc === JSONRPC_VERSION &&\n    95→        typeof message.method === 'string' &&\n    96→        'id' in message &&\n    97→        message.id !== undefined &&\n    98→        message.id !== null\n    99→    );\n   100→}"}]},"parent_tool_use_id":"toolu_01AU7kaGXRrmfPoh4L8qumog","session_id":"98ef6066-2367-415b-b616-f95ed64be17a","uuid":"6e38426a-cdbd-4661-88a0-e226703e716f"}
