{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017vAbRTQjVVsrKyqA5CXpZt","type":"tool_result","content":"     1→/**\n     2→ * Handler Registry System\n     3→ * Manages registration and routing of internal message handlers\n     4→ */\n     5→\n     6→import { Response } from 'express';\n     7→import { logInfo, logError, logDebug } from '@officeagent/core';\n     8→import {\n     9→    InternalMessageType,\n    10→    HandlerContext,\n    11→    InternalError,\n    12→    InternalErrorCode,\n    13→} from '../types/base-types';\n    14→\n    15→/**\n    16→ * Streaming context passed to streaming handlers\n    17→ * Provides methods to write SSE data to the response\n    18→ */\n    19→export interface StreamingContext extends HandlerContext {\n    20→    /** Express response object for writing streaming data */\n    21→    res: Response;\n    22→    /** Write SSE data chunk */\n    23→    writeChunk: (data: string) => void;\n    24→    /** Write SSE event with data */\n    25→    writeEvent: (event: string, data: unknown) => void;\n    26→    /** End the streaming response */\n    27→    end: () => void;\n    28→    /** Check if response is still writable */\n    29→    isWritable: () => boolean;\n    30→}\n    31→\n    32→/**\n    33→ * Interface that all message handlers must implement\n    34→ * @template TRequest - Type of the request payload\n    35→ * @template TResponse - Type of the response data\n    36→ */\n    37→export interface InternalMessageHandler<TRequest = unknown, TResponse = unknown> {\n    38→    /**\n    39→     * Handle the request and return response data (non-streaming)\n    40→     * @param request - Validated request payload\n    41→     * @param context - Handler context with utilities and metadata\n    42→     * @returns Promise resolving to response data\n    43→     * @throws Error if handling fails (will be converted to InternalError)\n    44→     */\n    45→    handle(request: TRequest, context: HandlerContext): Promise<TResponse>;\n    46→\n    47→    /**\n    48→     * Validate and parse the request payload\n    49→     * @param payload - Raw payload from request\n    50→     * @returns Validated and typed request object\n    51→     * @throws Error with descriptive message if validation fails\n    52→     */\n    53→    validate(payload: unknown): TRequest;\n    54→\n    55→    /**\n    56→     * Optional timeout in milliseconds for this handler\n    57→     * Default: 30000ms (30 seconds)\n    58→     */\n    59→    timeout?: number;\n    60→\n    61→    /**\n    62→     * Whether this handler supports streaming responses\n    63→     * If true, handleStream must be implemented\n    64→     */\n    65→    supportsStreaming?: boolean;\n    66→\n    67→    /**\n    68→     * Handle the request with streaming response\n    69→     * Only called if supportsStreaming is true and request has stream: true\n    70→     * @param request - Validated request payload\n    71→     * @param context - Streaming context with response writing methods\n    72→     * @returns Promise that resolves when streaming is complete\n    73→     */\n    74→    handleStream?(request: TRequest, context: StreamingContext): Promise<void>;\n    75→}\n    76→\n    77→/**\n    78→ * Handler registry configuration\n    79→ */\n    80→export interface HandlerRegistryConfig {\n    81→    /** Default timeout for handlers that don't specify one */\n    82→    defaultTimeout?: number;\n    83→    /** Whether to log handler registrations */\n    84→    logRegistrations?: boolean;\n    85→}\n    86→\n    87→/**\n    88→ * Handler Registry\n    89→ * Central registry for all internal message handlers\n    90→ */\n    91→export class HandlerRegistry {\n    92→    private handlers: Map<InternalMessageType, InternalMessageHandler<any, any>>;\n    93→    private config: HandlerRegistryConfig;\n    94→\n    95→    constructor(config: HandlerRegistryConfig = {}) {\n    96→        this.handlers = new Map();\n    97→        this.config = {\n    98→            defaultTimeout: 30000, // 30 seconds\n    99→            logRegistrations: true,\n   100→            ...config,\n   101→        };\n   102→    }\n   103→\n   104→    /**\n   105→     * Register a handler for a specific message type\n   106→     * @param messageType - The message type to handle\n   107→     * @param handler - The handler implementation\n   108→     */\n   109→    register<TRequest, TResponse>(\n   110→        messageType: InternalMessageType,\n   111→        handler: InternalMessageHandler<TRequest, TResponse>\n   112→    ): void {\n   113→        if (this.handlers.has(messageType)) {\n   114→            logError(0x1e0dc18d /* tag_4d2gn */, `Handler already registered for message type: ${messageType}`);\n   115→            throw new Error(`Handler already registered for message type: ${messageType}`);\n   116→        }\n   117→\n   118→        this.handlers.set(messageType, handler);\n   119→\n   120→        if (this.config.logRegistrations) {\n   121→            const timeout = handler.timeout || this.config.defaultTimeout;\n   122→            logInfo(0x1e0dc18c /* tag_4d2gm */, `Registered handler for '${messageType}' (timeout: ${timeout}ms)`);\n   123→        }\n   124→    }\n   125→\n   126→    /**\n   127→     * Unregister a handler for a specific message type\n   128→     * Useful for testing or dynamic handler management\n   129→     * @param messageType - The message type to unregister\n   130→     */\n   131→    unregister(messageType: InternalMessageType): boolean {\n   132→        const existed = this.handlers.delete(messageType);\n   133→        if (existed && this.config.logRegistrations) {\n   134→            logInfo(0x1e0dc18b /* tag_4d2gl */, `Unregistered handler for '${messageType}'`);\n   135→        }\n   136→        return existed;\n   137→    }\n   138→\n   139→    /**\n   140→     * Check if a handler is registered for a message type\n   141→     * @param messageType - The message type to check\n   142→     */\n   143→    isRegistered(messageType: InternalMessageType): boolean {\n   144→        return this.handlers.has(messageType);\n   145→    }\n   146→\n   147→    /**\n   148→     * Get a handler for a specific message type\n   149→     * @param messageType - The message type\n   150→     * @returns The handler or undefined if not registered\n   151→     */\n   152→    getHandler(messageType: InternalMessageType): InternalMessageHandler<any, any> | undefined {\n   153→        return this.handlers.get(messageType);\n   154→    }\n   155→\n   156→    /**\n   157→     * Get all registered message types\n   158→     */\n   159→    getRegisteredTypes(): InternalMessageType[] {\n   160→        return Array.from(this.handlers.keys());\n   161→    }\n   162→\n   163→    /**\n   164→     * Get the timeout for a specific message type\n   165→     * @param messageType - The message type\n   166→     * @returns Timeout in milliseconds\n   167→     */\n   168→    getTimeout(messageType: InternalMessageType): number {\n   169→        const handler = this.handlers.get(messageType);\n   170→        return handler?.timeout || this.config.defaultTimeout!;\n   171→    }\n   172→\n   173→    /**\n   174→     * Validate a request payload using the registered handler\n   175→     * @param messageType - The message type\n   176→     * @param payload - The raw payload to validate\n   177→     * @returns Validated payload\n   178→     * @throws InternalError if validation fails\n   179→     */\n   180→    validatePayload<T>(messageType: InternalMessageType, payload: unknown): T {\n   181→        const handler = this.handlers.get(messageType);\n   182→\n   183→        if (!handler) {\n   184→            throw this.createError(\n   185→                InternalErrorCode.UNSUPPORTED_MESSAGE_TYPE,\n   186→                `No handler registered for message type: ${messageType}`\n   187→            );\n   188→        }\n   189→\n   190→        try {\n   191→            return handler.validate(payload) as T;\n   192→        } catch (error: any) {\n   193→            logError(0x1e06065a /* tag_4b6z0 */, `Validation failed for ${messageType}: ${error.message}`);\n   194→            throw this.createError(\n   195→                InternalErrorCode.VALIDATION_ERROR,\n   196→                `Validation failed: ${error.message}`,\n   197→                error\n   198→            );\n   199→        }\n   200→    }\n   201→\n   202→    /**\n   203→     * Execute a handler for a specific message type\n   204→     * @param messageType - The message type\n   205→     * @param payload - Validated payload\n   206→     * @param context - Handler context\n   207→     * @returns Promise resolving to response data\n   208→     * @throws InternalError if execution fails\n   209→     */\n   210→    async executeHandler<TRequest, TResponse>(\n   211→        messageType: InternalMessageType,\n   212→        payload: TRequest,\n   213→        context: HandlerContext\n   214→    ): Promise<TResponse> {\n   215→        const handler = this.handlers.get(messageType);\n   216→\n   217→        if (!handler) {\n   218→            throw this.createError(\n   219→                InternalErrorCode.UNSUPPORTED_MESSAGE_TYPE,\n   220→                `No handler registered for message type: ${messageType}`\n   221→            );\n   222→        }\n   223→\n   224→        try {\n   225→            logDebug(`Executing handler for ${messageType} (requestId: ${context.requestId})`);\n   226→            const result = await handler.handle(payload, context);\n   227→            logDebug(`Handler completed for ${messageType} (requestId: ${context.requestId})`);\n   228→            return result;\n   229→        } catch (error: any) {\n   230→            logError(0x1e0dc18a /* tag_4d2gk */, `Handler execution failed for ${messageType}:`, error);\n   231→            throw this.createError(\n   232→                InternalErrorCode.HANDLER_ERROR,\n   233→                `Handler execution failed: ${error.message}`,\n   234→                error\n   235→            );\n   236→        }\n   237→    }\n   238→\n   239→    /**\n   240→     * Check if a handler supports streaming\n   241→     * @param messageType - The message type\n   242→     * @returns true if the handler supports streaming\n   243→     */\n   244→    supportsStreaming(messageType: InternalMessageType): boolean {\n   245→        const handler = this.handlers.get(messageType);\n   246→        return handler?.supportsStreaming === true && typeof handler.handleStream === 'function';\n   247→    }\n   248→\n   249→    /**\n   250→     * Execute a streaming handler for a specific message type\n   251→     * @param messageType - The message type\n   252→     * @param payload - Validated payload\n   253→     * @param context - Streaming context with response writing methods\n   254→     * @returns Promise that resolves when streaming is complete\n   255→     * @throws InternalError if execution fails\n   256→     */\n   257→    async executeStreamingHandler<TRequest>(\n   258→        messageType: InternalMessageType,\n   259→        payload: TRequest,\n   260→        context: StreamingContext\n   261→    ): Promise<void> {\n   262→        const handler = this.handlers.get(messageType);\n   263→\n   264→        if (!handler) {\n   265→            throw this.createError(\n   266→                InternalErrorCode.UNSUPPORTED_MESSAGE_TYPE,\n   267→                `No handler registered for message type: ${messageType}`\n   268→            );\n   269→        }\n   270→\n   271→        if (!handler.supportsStreaming || !handler.handleStream) {\n   272→            throw this.createError(\n   273→                InternalErrorCode.HANDLER_ERROR,\n   274→                `Handler for ${messageType} does not support streaming`\n   275→            );\n   276→        }\n   277→\n   278→        try {\n   279→            logDebug(`Executing streaming handler for ${messageType} (requestId: ${context.requestId})`);\n   280→            await handler.handleStream(payload, context);\n   281→            logDebug(`Streaming handler completed for ${messageType} (requestId: ${context.requestId})`);\n   282→        } catch (error: any) {\n   283→            logError(0x1e0d8463 /* tag_4dyr9 */, `Streaming handler execution failed for ${messageType}:`, error);\n   284→            throw this.createError(\n   285→                InternalErrorCode.HANDLER_ERROR,\n   286→                `Streaming handler execution failed: ${error.message}`,\n   287→                error\n   288→            );\n   289→        }\n   290→    }\n   291→\n   292→    /**\n   293→     * Helper to create standardized internal errors\n   294→     */\n   295→    private createError(code: InternalErrorCode, message: string, details?: unknown): InternalError {\n   296→        return {\n   297→            code,\n   298→            message,\n   299→            details,\n   300→        };\n   301→    }\n   302→\n   303→    /**\n   304→     * Clear all registered handlers\n   305→     * Useful for testing\n   306→     */\n   307→    clear(): void {\n   308→        this.handlers.clear();\n   309→        if (this.config.logRegistrations) {\n   310→            logInfo(0x1e0dc189 /* tag_4d2gj */, 'Cleared all registered handlers');\n   311→        }\n   312→    }\n   313→\n   314→    /**\n   315→     * Get registry statistics\n   316→     */\n   317→    getStats() {\n   318→        return {\n   319→            totalHandlers: this.handlers.size,\n   320→            registeredTypes: this.getRegisteredTypes(),\n   321→            defaultTimeout: this.config.defaultTimeout,\n   322→        };\n   323→    }\n   324→}\n   325→\n   326→/**\n   327→ * Global handler registry instance\n   328→ * Export as singleton for use throughout the application\n   329→ */\n   330→export const globalRegistry = new HandlerRegistry();\n   331→\n   332→/**\n   333→ * Export convenience function to register handlers\n   334→ */\n   335→export function registerHandler<TRequest, TResponse>(\n   336→    messageType: InternalMessageType,\n   337→    handler: InternalMessageHandler<TRequest, TResponse>\n   338→): void {\n   339→    globalRegistry.register(messageType, handler);\n   340→}\n   341→"}]},"parent_tool_use_id":"toolu_01AU7kaGXRrmfPoh4L8qumog","session_id":"98ef6066-2367-415b-b616-f95ed64be17a","uuid":"30682aa0-2cd9-49a4-b35a-71e569eb1ed8"}
