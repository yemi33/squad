{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01P9DnuXxYKdgHQa6SHf9smE","type":"tool_result","content":"     1→import express, { Request, Response } from 'express';\n     2→import fs from 'fs/promises';\n     3→import { createServer, Server } from 'http';\n     4→import path from 'path';\n     5→import { chromium } from 'playwright';\n     6→import { v4 as uuidv4 } from 'uuid';\n     7→import contentDisposition from 'content-disposition';\n     8→\n     9→import { logInfo, logDebug, logError, getAndClearLogEntries, AgentWorkspaceManager, AgentRegistry, SessionContext, wsRouter, wsManager, OfficeAgentSettingsManager } from '@officeagent/core';\n    10→\n    11→export function registerExternalRouteHandlers(externalPort: number, internalPort: number, settingsManager: OfficeAgentSettingsManager): { externalServer: Server, externalApp: express.Express } {\n    12→    const externalServer = createServer();\n    13→\n    14→    const externalApp = express();\n    15→    externalApp.use(express.json({ limit: '20mb' })); // Increasing limit for large requests\n    16→    externalApp.use(express.urlencoded({ extended: true, limit: '20mb' }));\n    17→\n    18→    // HTTP API Endpoints\n    19→\n    20→    // Keep alive ping endpoint\n    21→    externalApp.get('/ping', async (req: Request, res: Response) => {\n    22→        logInfo(0x1e0dc186 /* tag_4d2gg */, 'GET Ping endpoint hit');\n    23→        res.send({ message: 'pong' });\n    24→    });\n    25→\n    26→    // Build health verification, performing extended checks\n    27→    externalApp.get('/test', async (req: Request, res: Response) => {\n    28→        logInfo(0x1e0dc185 /* tag_4d2gf */, 'GET Test endpoint hit');\n    29→        try {\n    30→            await performExtendedHealthCheck(externalPort, internalPort, externalApp, settingsManager);\n    31→        } catch (error: any) {\n    32→            logError(0x1e0dc184 /* tag_4d2ge */, `❌ Health check failed: ${error?.stack ?? error}`);\n    33→            if (process.env.OfficePy__Deployment__LocalhostOfficeAgentDevelopment === 'True') {\n    34→                res.status(500).send(`Internal Server Error: ${error?.stack ?? error}`);\n    35→            } else {\n    36→                res.status(500).send('Internal Server Error');\n    37→            }\n    38→            return;\n    39→        }\n    40→        res.send({ message: `Hello World, ${Date.now()}` });\n    41→    });\n    42→\n    43→    // Download file from inside file manager folder only\n    44→    externalApp.get('/download', async (req: Request, res: Response) => {\n    45→        try {\n    46→            logInfo(0x1e0dc183 /* tag_4d2gd */, 'Attempting to read file');\n    47→            const filePath = req.query.filePath as string;\n    48→\n    49→            if (!filePath) {\n    50→                res.status(400).send('Missing required query parameter: filePath');\n    51→                return;\n    52→            }\n    53→            logDebug(`Requested file: ${filePath}`);\n    54→\n    55→            let normalizedFilePath = path.normalize(filePath);\n    56→            if (\n    57→                process.env.OfficePy__Deployment__LocalhostOfficeAgentDevelopment !== 'True' &&\n    58→                !AgentWorkspaceManager.isValidOutputDir(normalizedFilePath)\n    59→            ) {\n    60→                res.status(403).send('Invalid filePath');\n    61→                return;\n    62→            }\n    63→\n    64→            const fileContent = await fs.readFile(normalizedFilePath);\n    65→            logInfo(0x1e0dc182 /* tag_4d2gc */, `File read successfully, size: ${fileContent.length} bytes`);\n    66→            res.writeHead(200, {\n    67→                'Content-Type': 'application/octet-stream',\n    68→                'Content-Disposition': contentDisposition(encodeURIComponent(path.basename(normalizedFilePath)), { type: 'attachment' }),\n    69→                'Content-Length': fileContent.length\n    70→            });\n    71→            res.end(fileContent);\n    72→            logDebug('/download - File sent');\n    73→        } catch (error: any) {\n    74→            logError(0x1e0dc181 /* tag_4d2gb */, `Error reading file: ${error.message}`);\n    75→            res.writeHead(404);\n    76→            res.end('File not found: ' + error.message);\n    77→        }\n    78→    });\n    79→\n    80→    // Health check endpoint for resilience monitoring\n    81→    externalApp.get('/health', (req: Request, res: Response) => {\n    82→        const health = getHealthStatus(externalPort, internalPort);\n    83→        health.status = 'healthy';\n    84→        res.json(health);\n    85→    });\n    86→\n    87→    // GET /logs endpoint\n    88→    externalApp.get('/logs', (req, res) => {\n    89→        const logEntries = getAndClearLogEntries();\n    90→        logInfo(0x1e0dc180 /* tag_4d2ga */, `Returning ${logEntries?.length} log entries`);\n    91→        res.json({\n    92→            'items': logEntries\n    93→        });\n    94→    });\n    95→\n    96→    // Upload endpoint: accepts binary PPTX (or any file) via application/octet-stream\n    97→    // Used by PptAgent (via OfficePyClient.sendRequest) to push files into the container workspace.\n    98→    // Pairs with the existing /download endpoint for bidirectional file transfer.\n    99→    const uploadSizeLimit = process.env.OFFICEAGENT_UPLOAD_SIZE_LIMIT || '500mb';\n   100→    const rawOctetParser = express.raw({ type: 'application/octet-stream', limit: uploadSizeLimit });\n   101→\n   102→    const parseUploadRequest = (req: Request, res: Response): { normalizedFilePath: string; fileData: Buffer } | null => {\n   103→        const rawFilePath = req.query.filePath as string;\n   104→        if (!rawFilePath) {\n   105→            res.status(400).json({ error: 'Missing required query parameter: filePath' });\n   106→            return null;\n   107→        }\n   108→\n   109→        const normalizedFilePath = path.normalize(rawFilePath);\n   110→\n   111→        // Validate the path is within the agent workspace\n   112→        if (\n   113→            process.env.OfficePy__Deployment__LocalhostOfficeAgentDevelopment !== 'True' &&\n   114→            !AgentWorkspaceManager.isValidOutputDir(normalizedFilePath)\n   115→        ) {\n   116→            res.status(403).json({ error: 'Invalid filePath — must be within agent workspace' });\n   117→            return null;\n   118→        }\n   119→\n   120→        const fileData = req.body as Buffer;\n   121→        if (!fileData || fileData.length === 0) {\n   122→            res.status(400).json({ error: 'Empty request body' });\n   123→            return null;\n   124→        }\n   125→\n   126→        return { normalizedFilePath, fileData };\n   127→    };\n   128→\n   129→    externalApp.post('/upload', rawOctetParser, async (req: Request, res: Response, next: any) => {\n   130→        try {\n   131→            const parsed = parseUploadRequest(req, res);\n   132→            if (!parsed) return;\n   133→            const { normalizedFilePath, fileData } = parsed;\n   134→\n   135→            // Ensure parent directory exists\n   136→            await fs.mkdir(path.dirname(normalizedFilePath), { recursive: true });\n   137→            await fs.writeFile(normalizedFilePath, fileData);\n   138→            logInfo(0x1e04b2a2 /* tag_4blk8 */, `[Upload] File written: ${fileData.length} bytes`);\n   139→\n   140→            res.status(200).json({ success: true, normalizedFilePath, size: fileData.length });\n   141→        } catch (e) {\n   142→            next(e);\n   143→        }\n   144→    });\n   145→\n   146→    externalApp.patch('/upload', rawOctetParser, async (req: Request, res: Response, next: any) => {\n   147→        try {\n   148→            const parsed = parseUploadRequest(req, res);\n   149→            if (!parsed) return;\n   150→            const { normalizedFilePath, fileData } = parsed;"}]},"parent_tool_use_id":"toolu_01AU7kaGXRrmfPoh4L8qumog","session_id":"98ef6066-2367-415b-b616-f95ed64be17a","uuid":"b4ce62ac-30d8-4c4c-a950-50c62123d8a1"}
