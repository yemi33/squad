Substrate flag was set\n   318→        if (hasEnterpriseSearchV2Flag || hasSkillsVersion0Flag) {\n   319→            const context = (createAgent as any).context;\n   320→            if (context) {\n   321→                if (hasEnterpriseSearchV2Flag) {\n   322→                    logInfo(0x1e0dc1c1 /* tag_4d2hb */, '[CreateAgentV2] Re-initializing agent with updated Enterprise Substrate Strategy configuration');\n   323→                }\n   324→                if (hasSkillsVersion0Flag) {\n   325→                    logInfo(0x1e0dc1c0 /* tag_4d2ha */, '[CreateAgentV2] Re-initializing agent with updated skill version 0.0.1 configuration');\n   326→                }\n   327→                await createAgent.initialize(context);\n   328→                logInfo(0x1e0dc1a3 /* tag_4d2g9 */, '[CreateAgentV2] Agent re-initialized successfully');\n   329→            } else {\n   330→                logWarn(0x1e0dc1a2 /* tag_4d2g8 */, '[CreateAgentV2] Agent context not available, cannot re-initialize agent');\n   331→            }\n   332→        }\n   333→\n   334→        res.setHeader('OfficeAgentVersion', process.env.OFFICE_AGENT_VERSION || 'unknown');\n   335→        if (returnAsync) {\n   336→            res.status(202).json({\n   337→                success: true,\n   338→                message: 'Document generation started',\n   339→                requestId: finalRequestId,\n   340→                conversationId: finalConversationId,\n   341→            });\n   342→        }\n   343→\n   344→        // Use queryAnnotations directly from request body\n   345→        const queryAnnotationsForContext = Array.isArray(queryAnnotations) && queryAnnotations.length > 0\n   346→            ? queryAnnotations\n   347→            : undefined;\n   348→\n   349→        // Use provisionedFileMetadata directly from request body\n   350→        const provisionedFileMetadataForContext = Array.isArray(provisionedFileMetadata) && provisionedFileMetadata.length > 0\n   351→          