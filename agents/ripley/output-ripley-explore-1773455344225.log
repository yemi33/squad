{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015QqPRBMcuxbEfA9qxuLzTm","type":"tool_result","content":"     1→function getConfig() {\n     2→  const repoWideChangeFiles = [\n     3→    'gulp-tasks/**/*',\n     4→    '*.js',\n     5→    '*.json',\n     6→    '*.mjs',\n     7→    '*.toml',\n     8→    '*.ini'\n     9→  ];\n    10→  const config = {\n    11→    pipeline: {\n    12→      build: {\n    13→        dependsOn: ['^build'],\n    14→        inputs: ['src/**', 'tsconfig.json', 'package.json', 'pyproject.toml', 'projects.json'],\n    15→        outputs: ['dist/**', '.build/.pyproject-hash'],\n    16→      },\n    17→      clean: {\n    18→        dependsOn: [],\n    19→      },\n    20→      lint: {\n    21→        dependsOn: [],\n    22→      },\n    23→      'lint:fix': {\n    24→        dependsOn: ['^lint:fix'],\n    25→      },\n    26→      test: {\n    27→        dependsOn: []\n    28→      },\n    29→    },\n    30→    // If any files within \"repoWideChanges\" are changed, disable the \"--since\" option; caching is not affected by this flag\n    31→    repoWideChanges: repoWideChangeFiles,\n    32→    cacheOptions: {\n    33→      // These are relative to the git root, and affect the hash of the cache.\n    34→      // Changes to any of these files will invalidate the cache.\n    35→      environmentGlob: repoWideChangeFiles\n    36→    },\n    37→    npmClient: 'yarn'\n    38→  };\n    39→\n    40→  return config;\n    41→}\n    42→\n    43→module.exports = getConfig();\n    44→"}]},"parent_tool_use_id":"toolu_01JFxuCnY2KejKQcmVMsFzvh","session_id":"98ef6066-2367-415b-b616-f95ed64be17a","uuid":"831dcba8-d70c-4e8d-bc4d-f00f8608a686"}
