{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PLCeeiJw1gFs1Zg4aTCspG","type":"tool_result","content":"     1→import { logWarn } from '../logging';\n     2→import { BaseAgent } from './base-agent';\n     3→\n     4→/**\n     5→ * Simple in-memory registry for manually registered agents.\n     6→ * Agents must call this registry during startup to make themselves discoverable.\n     7→ */\n     8→export class AgentRegistry {\n     9→    private static agents = new Map<string, BaseAgent>();\n    10→\n    11→    /**\n    12→     * Register an agent and its metadata.\n    13→     */\n    14→    static registerAgent(agent: BaseAgent): void {\n    15→        if (this.agents.has(agent.agentId)) {\n    16→            logWarn(0x1e0dc096 /* tag_4d2cw */, `Agent ${agent.agentId} is already registered. Overwriting.`);\n    17→        }\n    18→\n    19→        this.agents.set(agent.agentId, agent);\n    20→    }\n    21→\n    22→    /**\n    23→     * Get agent metadata by ID.\n    24→     */\n    25→    static getAgent(agentId: string): BaseAgent | undefined {\n    26→        return this.agents.get(agentId);\n    27→    }\n    28→\n    29→    /**\n    30→     * Get all registered agents.\n    31→     */\n    32→    static getAllAgents(): BaseAgent[] {\n    33→        return Array.from(this.agents.values());\n    34→    }\n    35→\n    36→    /**\n    37→     * Clear all registered agents (useful for testing).\n    38→     */\n    39→    static clear(): void {\n    40→        this.agents.clear();\n    41→    }\n    42→}\n    43→"}]},"parent_tool_use_id":"toolu_01AU7kaGXRrmfPoh4L8qumog","session_id":"98ef6066-2367-415b-b616-f95ed64be17a","uuid":"4d2db6ce-069f-4514-b816-61d19a223558"}
