{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01BHPL1JEtBLGrdZFcq2vA5H","type":"tool_result","content":"     1→/**\n     2→ * @officeagent/orchestrator\n     3→ *\n     4→ * Abstraction layer for multi-provider agent orchestration.\n     5→ * Agents program against IOrchestrator — the factory handles provider selection.\n     6→ */\n     7→\n     8→// Core types\n     9→export {\n    10→    IOrchestrator,\n    11→    OrchestratorRequest,\n    12→    OrchestratorResult,\n    13→    OrchestratorHooks,\n    14→    OrchestratorMessage,\n    15→    OrchestratorUsage,\n    16→    OrchestratorToolInput,\n    17→    OrchestratorToolDecision,\n    18→    OrchestratorToolOutput,\n    19→} from './types';\n    20→\n    21→// Generic tool hooks (provider-agnostic)\n    22→export type {\n    23→    GenericToolHooks,\n    24→    PreToolUseHook,\n    25→    PreToolUseResult,\n    26→    PostToolUseHook,\n    27→    PostToolUseResult,\n    28→    SessionHook,\n    29→    SessionContext,\n    30→} from './types';\n    31→\n    32→// Hook adapters\n    33→export { toClaudeHooks, mergeWithClaudeHooks } from './hooks/claude-hook-adapter';\n    34→\n    35→// Factory\n    36→export {\n    37→    createOrchestrator,\n    38→    registerProvider,\n    39→    unregisterProvider,\n    40→    listProviders,\n    41→} from './factory';\n    42→export type { HarnessType, OrchestratorFactory } from './factory';\n    43→\n    44→// Providers (for direct instantiation when needed)\n    45→export { BaseOrchestrator } from './providers';\n    46→export type { ToolPermissionResult } from './providers';\n    47→export { ClaudeOrchestrator, GhcpOrchestrator } from './providers';\n    48→\n    49→// Adapters\n    50→export { toChainOfThoughtMessage, ChainOfThoughtAdapter } from './cot-adapter';\n    51→\n    52→// Constants\n    53→export { GPT5_MODEL_PREFIX } from './constants';\n    54→\n    55→// Utilities\n    56→export { dynamicImport, getProviderConfig, isOpenAiProvider, isAnthropicProvider } from './utils';\n    57→export type { ProviderConfig } from './utils';\n    58→\n    59→// HarnessBuilder\n    60→export { HarnessBuilder } from './harness-builder';\n    61→\n    62→\n    63→// Env resolvers\n    64→export { buildEnv, ENV_FEATURE_GATES, ENV_SETTING_KEYS } from './env-builder';\n    65→export type { FeatureGateSetting, AgentEnvContext } from './env-builder';\n    66→"}]},"parent_tool_use_id":"toolu_01AU7kaGXRrmfPoh4L8qumog","session_id":"98ef6066-2367-415b-b616-f95ed64be17a","uuid":"6eea83a9-7e98-4fc1-b349-c3bb66b9b88b"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CJNcLWfjiKG6ocvsctBHNF","type":"tool_result","content":"     1→// Export all enterprise search tool types and classes\n     2→export { EnterpriseSearchEntityType } from '@officeagent/message-protocol';\n     3→\n     4→// =============================================================================\n     5→// NEW PIPELINE ARCHITECTURE\n     6→// =============================================================================\n     7→\n     8→// Core types and interfaces\n     9→export * from './types';\n    10→\n    11→// Grounding modules\n    12→export * from './enterprise';\n    13→export * from './images';\n    14→\n    15→// Shared utilities\n    16→export * from './shared';\n    17→export { parseGroundingContent } from './grounding-content-parser';\n    18→export type { GroundingContentWithAnnotations } from './grounding-content-parser';\n    19→\n    20→export * from './orchestrator';\n    21→export * from './base-preprocessor';\n    22→export * from './base-retriever';\n    23→export * from './base-postprocessor';\n    24→export * from './base-storage';\n    25→export * from './noops';\n    26→export * from './user-attachment';\n    27→\n    28→// Agent-to-Agent (A2A) communication — HTTP server, client, and types\n    29→export * from './api';\n    30→"}]},"parent_tool_use_id":"toolu_01AU7kaGXRrmfPoh4L8qumog","session_id":"98ef6066-2367-415b-b616-f95ed64be17a","uuid":"e13f4b9f-e570-465c-9308-88ec06f631eb"}
