{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01MpZ2jB226QCQ7cLwY7TucZ","type":"tool_result","content":"     1→/**\n     2→ * Orchestrator abstraction layer types.\n     3→ *\n     4→ * Defines the contract that all orchestrator providers must implement,\n     5→ * enabling agents to be decoupled from any specific AI SDK.\n     6→ */\n     7→\n     8→// ---------------------------------------------------------------------------\n     9→// Core Orchestrator Interface\n    10→// ---------------------------------------------------------------------------\n    11→\n    12→/**\n    13→ * Core orchestrator interface.\n    14→ *\n    15→ * Each provider (Claude, GitHub Copilot, etc.) implements this to wrap its SDK\n    16→ * behind a unified API. Agents program against this interface — the factory\n    17→ * handles provider selection at runtime.\n    18→ *\n    19→ * Two execution modes:\n    20→ * - `run()` — batch: returns the final result (simple callers like grounding-agent)\n    21→ * - `runStream()` — streaming: yields each message as it arrives (create-agent, ppt-agent, etc.)\n    22→ */\n    23→export interface IOrchestrator {\n    24→    /**\n    25→     * Execute a prompt and return the final result (batch mode).\n    26→     *\n    27→     * Default implementation delegates to `runStream()` and collects the terminal result.\n    28→     * Providers may override for optimization.\n    29→     *\n    30→     * @param request - The orchestration request containing prompt, config, and hooks\n    31→     * @returns The final result after the orchestrator completes (or fails)\n    32→     */\n    33→    run(request: OrchestratorRequest): Promise<OrchestratorResult>;\n    34→\n    35→    /**\n    36→     * Execute a prompt and stream normalized messages as they arrive.\n    37→     *\n    38→     * The iterable yields `OrchestratorMessage` objects in real-time:\n    39→     * - `system` — session init, metadata\n    40→     * - `assistant` — reasoning / text output\n    41→     * - `tool_use` — tool invocation (name + input)\n    42→     * - `tool_result` — tool output\n    43→     * - `result` — terminal message with embedded `OrchestratorResult`\n    44→     *\n    45→     * The stream ends after yielding a `result`-type message.\n    46→     *\n    47→     * @param request - The orchestration request\n    48→     * @returns An async iterable of normalized messages\n    49→     */\n    50→    runStream(request: OrchestratorRequest): AsyncIterable<OrchestratorMessage>;\n    51→\n    52→    /**\n    53→     * Interrupt a running orchestrator execution.\n    54→     *\n    55→     * Maps to provider-specific abort mechanisms:\n    56→     * - Claude: `queryIterator.interrupt()`\n    57→     * - GHCP: `abortController.abort()`\n    58→     *\n    59→     * Safe to call when not running (no-op).\n    60→     */\n    61→    interrupt(): Promise<void>;\n    62→}\n    63→\n    64→// ---------------------------------------------------------------------------\n    65→// Request / Result / Message\n    66→// ---------------------------------------------------------------------------\n    67→\n    68→/**\n    69→ * Input to an orchestrator run.\n    70→ */\n    71→export interface OrchestratorRequest {\n    72→    /** The user prompt to send to the orchestrator */\n    73→    prompt: string;\n    74→    /** User context content to inject as a user message before the prompt */\n    75→    userContext?: string;\n    76→    /** System prompt defining agent behavior */\n    77→    systemPrompt?: string;\n    78→    /** Model identifier (provider-specific, e.g. 'claude-sonnet-4-5-20250929') */\n    79→    model?: string;\n    80→    /** Maximum number of agentic turns before stopping */\n    81→    maxTurns?: number;\n    82→    /**\n    83→     * Reasoning effort level hint.\n    84→     *\n    85→     * Accepts both GHCP ('xhigh') and Claude ('max') top-tier values.\n    86→     * Providers normalize as appropriate:\n    87→     * - GHCP: 'max' → 'xhigh', rest passed directly as `reasoningEffort`\n    88→     * - Claude: 'xhigh' → 'max', rest passed directly as SDK `effort`\n    89→     */\n    90→    reasoningEffort?: 'low' | 'medium' | 'high' | 'max' | 'xhigh';\n    91→    /** List of tools the orchestrator is allowed to use (by name) */\n    92→    allowedTools?: string[];\n    93→    /** List of tools the orchestrator must not use */\n    94→    disallowedTools?: string[];\n    95→    /**\n    96→     * Full tool definitions for providers that require schemas (e.g. GitHub Copilot\n    97→     * function calling). Claude SDK manages its own tool definitions so this is ignored.\n    98→     * Shape is provider-dependent — use `unknown[]` and cast in the provider.\n    99→     */\n   100→    toolDefinitions?: unknown[];\n   101→    /** Working directory for tool execution */\n   102→    cwd?: string;\n   103→    /** Environment variables passed to the orchestrator process */\n   104→    env?: Record<string, string>;\n   105→    /** Abort controller for cancellation */\n   106→    abortController?: AbortController;\n   107→    /** Hooks for observing orchestrator activity (batch mode — used by run()) */\n   108→    hooks?: OrchestratorHooks;\n   109→    /** Provider-agnostic tool hooks for interception (pre/post tool calls) */\n   110→    toolHooks?: GenericToolHooks;\n   111→    /** Session ID for resuming a previous conversation (maps to Claude `resume`) */\n   112→    sessionId?: string;\n   113→    /**\n   114→     * Opaque provider-specific options.\n   115→     *\n   116→     * Examples:\n   117→     * - Claude: `{ continue: true, stderr: Writable, permissionMode: '...' }`\n   118→     * - GHCP: `{ token: '...', confirmationRequired: true }`\n   119→     */\n   120→    providerOptions?: Record<string, unknown>;\n   121→}\n   122→\n   123→/**\n   124→ * Result from an orchestrator run.\n   125→ */\n   126→/**\n   127→ * Standardized usage metrics.\n   128→ *\n   129→ * Providers populate whichever fields they can. The fields are intentionally\n   130→ * all optional — not every SDK exposes every metric.\n   131→ */\n   132→export interface OrchestratorUsage {\n   133→    /** Number of input / prompt tokens consumed */\n   134→    inputTokens?: number;\n   135→    /** Number of output / completion tokens generated */\n   136→    outputTokens?: number;\n   137→    /** Total tokens (input + output) — some providers report this directly */\n   138→    totalTokens?: number;\n   139→    /** Estimated cost in USD for this run */\n   140→    costUsd?: number;\n   141→    /** Wall-clock duration of the run in milliseconds */\n   142→    durationMs?: number;\n   143→    /** Number of agentic turns executed */\n   144→    turnCount?: number;\n   145→}\n   146→\n   147→export interface OrchestratorResult {\n   148→    /** The final text content produced by the orchestrator */\n   149→    content: string;\n   150→    /** Execution status */"}]},"parent_tool_use_id":"toolu_01AU7kaGXRrmfPoh4L8qumog","session_id":"98ef6066-2367-415b-b616-f95ed64be17a","uuid":"22635f3e-7b20-4f4f-b6a9-b45eb23df62d"}
