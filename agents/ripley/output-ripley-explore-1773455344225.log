{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018vbDZU3PKJSG2EedYHBeDE","type":"tool_result","content":"     1→/**\n     2→ * Base retriever class for fetching data from enterprise sources.\n     3→ *\n     4→ * Retrievers are responsible for:\n     5→ * - Fetching data from external sources (WebSocket, cache, etc.)\n     6→ * - Handling timeouts and retries\n     7→ * - Converting external responses to internal format\n     8→ *\n     9→ * @module enterprise-grounding/retrieval\n    10→ */\n    11→\n    12→import {\n    13→    IRetriever,\n    14→    PipelineContext,\n    15→    RetrievalError\n    16→} from './types';\n    17→import { logDebug, logError } from '@officeagent/core';\n    18→\n    19→/**\n    20→ * Abstract base class for all retrievers.\n    21→ * Provides common execution structure and error handling.\n    22→ */\n    23→export abstract class BaseRetriever<TRequest, TResponse> implements IRetriever<TRequest, TResponse> {\n    24→    public abstract readonly name: string;\n    25→\n    26→    /**\n    27→     * Execute the retrieval stage\n    28→     */\n    29→    public async execute(input: TRequest, context: PipelineContext): Promise<TResponse> {\n    30→        const startTime = Date.now();\n    31→        logDebug(`[${this.name}] Starting retrieval for request ${context.requestId}`);\n    32→\n    33→        try {\n    34→            // Perform retrieval\n    35→            const result = await this.retrieve(input, context);\n    36→\n    37→            // Track timing\n    38→            const duration = Date.now() - startTime;\n    39→            if (context.timings) {\n    40→                context.timings.retrieval = duration;\n    41→            }\n    42→\n    43→            logDebug(`[${this.name}] Completed retrieval in ${duration}ms`);\n    44→            return result;\n    45→        } catch (error: any) {\n    46→            logError(0x1e06065d /* tag_4b6z3 */, `[${this.name}] Retrieval failed: ${error.message}`);\n    47→            throw new RetrievalError(\n    48→                `Retrieval failed: ${error.message}`,\n    49→                { originalError: error.message, input }\n    50→            );\n    51→        }\n    52→    }\n    53→\n    54→    /**\n    55→     * Perform the actual data retrieval.\n    56→     * Subclasses implement specific retrieval logic here.\n    57→     */\n    58→    protected abstract retrieve(input: TRequest, context: PipelineContext): Promise<TResponse>;\n    59→}\n    60→"}]},"parent_tool_use_id":"toolu_01AU7kaGXRrmfPoh4L8qumog","session_id":"98ef6066-2367-415b-b616-f95ed64be17a","uuid":"9a7a39c1-ab13-46fe-9c02-af7458c4ffdc"}
