{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01BBGYBkowv2NocpddjHuDmB","type":"tool_result","content":"     1→// mcp-handler.ts\n     2→// Example MCP (Model Context Protocol) handler\n     3→// This shows how teammates can easily add new protocol handlers\n     4→\n     5→import { Request, Response } from 'express';\n     6→import { Application } from 'express';\n     7→import { v4 as uuidv4 } from 'uuid';\n     8→import { logInfo, wsRouter, wsManager } from '@officeagent/core';\n     9→import {\n    10→    MessageType,\n    11→    MCPRequestMessage\n    12→\n    13→} from '@officeagent/message-protocol';\n    14→\n    15→// Track pending MCP requests\n    16→const pendingMCPRequests = new Map<string, Response>();\n    17→\n    18→/**\n    19→ * Handle MCP response messages from WebSocket clients\n    20→ */\n    21→function handleMCPResponse(message: any): boolean {\n    22→    if (message.type !== MessageType.MCPResponse) {\n    23→        return false; // Not an MCP response\n    24→    }\n    25→\n    26→    const requestId = message.requestId || message.id;\n    27→    if (!requestId || !pendingMCPRequests.has(requestId)) {\n    28→        logInfo(0x1e0dc0c7 /* tag_4d2dh */, 'Received MCP response for unknown request ID:', requestId);\n    29→        return true;\n    30→    }\n    31→\n    32→    const res = pendingMCPRequests.get(requestId)!;\n    33→    pendingMCPRequests.delete(requestId);\n    34→\n    35→    if (message.payload?.error) {\n    36→        res.status(500).json({ error: message.payload.error });\n    37→    } else {\n    38→        res.json(message.payload?.result || message.payload);\n    39→    }\n    40→\n    41→    return true;\n    42→}\n    43→\n    44→/**\n    45→ * Register MCP handlers\n    46→ */\n    47→export function registerMCPHandlers(\n    48→    app: Application\n    49→): void {\n    50→\n    51→    // Register with the global WebSocket router\n    52→    wsRouter.registerHandler(MessageType.MCPResponse, handleMCPResponse);\n    53→\n    54→    // HTTP endpoint for MCP requests\n    55→    app.post('/mcp/:method', (req: Request, res: Response) => {\n    56→        const requestId = uuidv4();\n    57→        const method = req.params.method;\n    58→        const sessionId = `mcp-session-${Date.now()}`;\n    59→\n    60→        const mcpPayload: MCPRequestMessage = {\n    61→            id: requestId,\n    62→            type: MessageType.MCPRequest,\n    63→            sessionId: sessionId,\n    64→            payload: {\n    65→                method: method,\n    66→                params: req.body\n    67→            }\n    68→        };\n    69→\n    70→        // Track the pending request\n    71→        pendingMCPRequests.set(requestId, res);\n    72→\n    73→        logInfo(0x1e0dc0c6 /* tag_4d2dg */, `Forwarding MCP request ${requestId} (${method}) to WebSocket client`);\n    74→\n    75→        if (!wsManager.isConnected()) {\n    76→            pendingMCPRequests.delete(requestId);\n    77→            return res.status(503).json({ error: 'No WebSocket client connected' });\n    78→        }\n    79→\n    80→        if (!wsManager.sendMessage(mcpPayload)) {\n    81→            pendingMCPRequests.delete(requestId);\n    82→            if (!res.headersSent) {\n    83→                res.status(500).json({ error: 'Failed to send MCP request' });\n    84→            }\n    85→        }\n    86→\n    87→        // Set timeout\n    88→        setTimeout(() => {\n    89→            if (pendingMCPRequests.has(requestId)) {\n    90→                pendingMCPRequests.delete(requestId);\n    91→                if (!res.headersSent) {\n    92→                    res.status(504).json({ error: 'MCP request timeout' });\n    93→                }\n    94→            }\n    95→        }, 30000); // 30 second timeout for MCP requests\n    96→    });\n    97→\n    98→    logInfo(0x1e0dc0c5 /* tag_4d2df */, '✅ MCP handlers registered');\n    99→}\n   100→"}]},"parent_tool_use_id":"toolu_01AU7kaGXRrmfPoh4L8qumog","session_id":"98ef6066-2367-415b-b616-f95ed64be17a","uuid":"5ac2e8a6-575f-44b3-8bee-1e91fc48005e"}
