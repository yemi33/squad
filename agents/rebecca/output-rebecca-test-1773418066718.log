{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Xak7tLbcHkEYHAqdLyDkhB","type":"tool_result","content":"     1→/**\n     2→ * Type definitions for the progression UI feature.\n     3→ *\n     4→ * Progression tracks the step-by-step progress of agent work per message.\n     5→ * UserQuestion supports mid-flow agent questions with optional suggestions.\n     6→ */\n     7→\n     8→export type ProgressionStepStatus = 'pending' | 'in-progress' | 'complete' | 'error';\n     9→\n    10→export type ProgressionStepKind = 'reasoning' | 'tool-call' | 'search' | 'analysis';\n    11→\n    12→export interface ProgressionStep {\n    13→  id: string;\n    14→  title: string;\n    15→  detail?: string;\n    16→  kind: ProgressionStepKind;\n    17→  status: ProgressionStepStatus;\n    18→  toolName?: string;\n    19→  references?: ProgressionReference[];\n    20→  startedAt?: number;\n    21→  completedAt?: number;\n    22→}\n    23→\n    24→export interface ProgressionReference {\n    25→  id: string;\n    26→  title: string;\n    27→  kind: 'file' | 'search' | 'document' | 'context' | 'url';\n    28→  url?: string;\n    29→  metadata?: Record<string, string>;\n    30→}\n    31→\n    32→export interface ProgressionState {\n    33→  steps: ProgressionStep[];\n    34→  summary?: string;\n    35→  isStreaming: boolean;\n    36→  skipped: boolean;\n    37→}\n    38→\n    39→export interface UserQuestion {\n    40→  id: string;\n    41→  messageId: string;\n    42→  text: string;\n    43→  suggestions?: string[];\n    44→  required: boolean;\n    45→  answeredWith?: string;\n    46→}\n    47→"}]},"parent_tool_use_id":null,"session_id":"af029b4f-20ba-46ac-a82f-6f0aa19f42ee","uuid":"487e22c5-18a3-46c2-aa41-08f20d7c25fe","tool_use_result":{"type":"text","file":{"filePath":"C:/Users/yemishin/worktrees/test-W008c/apps/bebop/src/features/progression/types/progression.ts","content":"/**\n * Type definitions for the progression UI feature.\n *\n * Progression tracks the step-by-step progress of agent work per message.\n * UserQuestion supports mid-flow agent questions with optional suggestions.\n */\n\nexport type ProgressionStepStatus = 'pending' | 'in-progress' | 'complete' | 'error';\n\nexport type ProgressionStepKind = 'reasoning' | 'tool-call' | 'search' | 'analysis';\n\nexport interface ProgressionStep {\n  id: string;\n  title: string;\n  detail?: string;\n  kind: ProgressionStepKind;\n  status: ProgressionStepStatus;\n  toolName?: string;\n  references?: ProgressionReference[];\n  startedAt?: number;\n  completedAt?: number;\n}\n\nexport interface ProgressionReference {\n  id: string;\n  title: string;\n  kind: 'file' | 'search' | 'document' | 'context' | 'url';\n  url?: string;\n  metadata?: Record<string, string>;\n}\n\nexport interface ProgressionState {\n  steps: ProgressionStep[];\n  summary?: string;\n  isStreaming: boolean;\n  skipped: boolean;\n}\n\nexport interface UserQuestion {\n  id: string;\n  messageId: string;\n  text: string;\n  suggestions?: string[];\n  required: boolean;\n  answeredWith?: string;\n}\n","numLines":47,"startLine":1,"totalLines":47}}}
